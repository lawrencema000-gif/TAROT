# ===========================================
# MOBILE APP CONFIGURATION
# ===========================================
# These are the ONLY environment variables needed for the Android app.
# Stripe is NOT used in the mobile app - it's for web version only.

# Supabase Configuration (Required)
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# RevenueCat API Key for Mobile App Billing (Required for mobile purchases)
# Get your API key from: https://app.revenuecat.com
# This enables Google Play Billing for Android app
VITE_REVENUECAT_API_KEY=goog_xxxxxxxxxxxxxxxx

# ===========================================
# SUPABASE DASHBOARD CONFIGURATION
# ===========================================
# IMPORTANT: You must configure these in your Supabase Dashboard:
#
# 1. Go to Authentication > URL Configuration
# 2. Add to "Redirect URLs":
#    - com.arcana.app://auth (for Android app)
#    - https://yourdomain.com (for web version)
#
# 3. For Google OAuth, go to Authentication > Providers > Google
#    - Enable the provider
#    - Add your Google OAuth credentials
#    - Enable "Skip nonce checks" for mobile compatibility

# ===========================================
# WEB VERSION ONLY (Not used in mobile app)
# ===========================================
# The following Stripe configuration is ONLY for the web version.
# Mobile app uses RevenueCat/Google Play Billing exclusively.
# DO NOT configure these for Android app builds.
#
# VITE_STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxx
# VITE_STRIPE_PRICE_MONTHLY=price_xxxxxxxxxxxxxxxx
# VITE_STRIPE_PRICE_YEARLY=price_xxxxxxxxxxxxxxxx
# VITE_STRIPE_PRICE_LIFETIME=price_xxxxxxxxxxxxxxxx
