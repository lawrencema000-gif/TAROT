# Supabase Configuration (Required)
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# RevenueCat API Key for Mobile App Billing (Required for mobile purchases)
# Get your API key from: https://app.revenuecat.com
# This enables Google Play Billing for Android app
VITE_REVENUECAT_API_KEY=goog_xxxxxxxxxxxxxxxx

# Stripe Configuration for Web Version (Optional - for web payments)
# Get these from: https://dashboard.stripe.com
# This enables direct Stripe payments on the web version (avoids 30% app store fee)

# Stripe Public Key (used in frontend)
VITE_STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxx

# Stripe Price IDs (create products in Stripe Dashboard first)
# Run: STRIPE_SECRET_KEY=sk_test_xxx node scripts/create-stripe-products.mjs
#
# Pricing Structure:
#   - Lifetime: $9.99 one-time (unlock everything + remove ads)
#   - Monthly: $2.99/month (optional recurring)
#   - Yearly: $19.99/year (optional recurring, best value)
#
VITE_STRIPE_PRICE_LIFETIME=price_xxxxxxxxxxxxxxxx
VITE_STRIPE_PRICE_MONTHLY=price_xxxxxxxxxxxxxxxx
VITE_STRIPE_PRICE_YEARLY=price_xxxxxxxxxxxxxxxx

# Stripe Secret Keys (used in Edge Functions - DO NOT use VITE_ prefix)
# These will be automatically available in Supabase Edge Functions
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx

# To use this file:
# 1. Copy this file to .env: cp .env.example .env
# 2. Replace the placeholder values with your actual credentials
# 3. Never commit .env to version control
# 4. For production, use live keys instead of test keys
