# ===========================================
# MOBILE APP CONFIGURATION
# ===========================================
# These are the ONLY environment variables needed for the Android app.
# Stripe is NOT used in the mobile app - it's for web version only.

# Supabase Configuration (Required)
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# RevenueCat API Key for Mobile App Billing (Required for mobile purchases)
# Get your API key from: https://app.revenuecat.com
# Same RevenueCat project handles both stores; the SDK key is distinct per
# platform. Premium purchased on one store unlocks the other automatically.
VITE_REVENUECAT_API_KEY=goog_xxxxxxxxxxxxxxxx           # Google Play (Android)
VITE_REVENUECAT_API_KEY_IOS=appl_xxxxxxxxxxxxxxxx       # App Store (iOS)

# AdMob iOS ad units — parallel set to the Android ones. Get from
# https://admob.google.com after registering the iOS app (com.arcana.app).
# Leave blank until iOS app is registered; ads will simply no-op.
VITE_ADMOB_BANNER_IOS=
VITE_ADMOB_INTERSTITIAL_IOS=
VITE_ADMOB_REWARDED_IOS=
VITE_ADMOB_APPOPEN_IOS=

# ===========================================
# SUPABASE DASHBOARD CONFIGURATION
# ===========================================
# IMPORTANT: You must configure these in your Supabase Dashboard:
#
# 1. Go to Authentication > URL Configuration
# 2. Add to "Redirect URLs":
#    - com.arcana.app://auth (for Android app)
#    - https://yourdomain.com (for web version)
#
# 3. For Google OAuth, go to Authentication > Providers > Google
#    - Enable the provider
#    - Add your Google OAuth credentials (see GOOGLE_OAUTH_SETUP.md)
#    - Enable "Skip nonce checks" for mobile compatibility
#
# ===========================================
# GOOGLE CLOUD CONFIGURATION (CRITICAL)
# ===========================================
# For Android app Google Sign-In to work, you MUST:
#
# 1. Use the SAME Google Cloud project linked to your Play Store Console
#    (In your case: ARCANA project, NOT the Gemini project)
#
# 2. Create TWO OAuth 2.0 Client IDs in that project:
#    a) Web Application (for Supabase and web version)
#    b) Android (for native Android app sign-in)
#
# 3. For the Android OAuth Client ID:
#    - Package name: com.arcana.app
#    - SHA-1 certificate fingerprints (from your keystore)
#      Get debug SHA-1: keytool -list -v -keystore ~/.android/debug.keystore -alias androiddebugkey -storepass android -keypass android
#      Get release SHA-1: keytool -list -v -keystore path/to/your-release-key.jks -alias your-key-alias
#
# 4. Add BOTH Client IDs to Supabase Auth > Providers > Google

# ===========================================
# WEB VERSION ONLY (Not used in mobile app)
# ===========================================
# The following Stripe configuration is ONLY for the web version.
# Mobile app uses RevenueCat/Google Play Billing exclusively.
# DO NOT configure these for Android app builds.
#
# VITE_STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxx
# VITE_STRIPE_PRICE_MONTHLY=price_xxxxxxxxxxxxxxxx
# VITE_STRIPE_PRICE_YEARLY=price_xxxxxxxxxxxxxxxx
# VITE_STRIPE_PRICE_LIFETIME=price_xxxxxxxxxxxxxxxx

# ===========================================
# ADMIN ACCESS
# ===========================================
# Comma-separated list of admin emails (client-side UI heuristic only;
# authoritative admin check is server-side via is_admin() RPC).
# VITE_ADMIN_EMAILS=admin1@example.com,admin2@example.com

# ===========================================
# ADSENSE SLOTS (web only)
# ===========================================
# Create ad units in AdSense dashboard → copy the data-ad-slot number here.
# Current setup: flanking sidebars on desktop ≥1400px only. The other slot
# names below are kept dormant in code for future activation without a
# code change — paste a slot ID and they'll start rendering.
# VITE_ADSENSE_SIDEBAR_LEFT_SLOT=1234567890
# VITE_ADSENSE_SIDEBAR_RIGHT_SLOT=1234567890
# VITE_ADSENSE_IN_ARTICLE_SLOT=
# VITE_ADSENSE_END_ARTICLE_SLOT=
# VITE_ADSENSE_BLOG_GRID_SLOT=

# ===========================================
# SUPABASE EDGE FUNCTION SECRETS (server-side only)
# ===========================================
# These are NOT VITE_-prefixed because they never ship to the client.
# Set them via the Supabase CLI:
#   /c/Users/lmao/node_modules/supabase/bin/supabase.exe secrets set NAME=value --project-ref ulzlthhkqjuohzjangcq
# OR via the dashboard: https://supabase.com/dashboard/project/ulzlthhkqjuohzjangcq/settings/functions
#
# Required for AI features (any one of the LLM keys lets the AI suite work;
# without all of them, the AI chain falls through to "no providers configured"
# and the relevant edge functions return 503):
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# PERPLEXITY_API_KEY=pplx-...            # geo-mentions only
#
# Required for transactional / marketing email (newsletter course, welcome,
# digest). Without RESEND_API_KEY the relevant fns no-op gracefully.
# RESEND_API_KEY=re_...
# NEWSLETTER_FROM_EMAIL=Arcana <noreply@tarotlife.app>   # must be verified in Resend
# NEWSLETTER_REPLY_TO=lawrence.ma000@gmail.com
#
# Required for Stripe webhooks (web subscription flow + report unlocks).
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
#
# Required for LiveKit (advisor session live audio/video).
# LIVEKIT_API_KEY=...
# LIVEKIT_API_SECRET=...
# LIVEKIT_WS_URL=wss://your-livekit-instance.livekit.cloud
#
# SEO + observability:
# GSC_SERVICE_ACCOUNT_JSON={"type":"service_account",...}  # whole JSON as one line
# BING_WEBMASTER_API_KEY=...
# INDEXNOW_KEY=...                       # also put the same value at /public/{key}.txt
# ADMIN_EMAIL=lawrence.ma000@gmail.com   # alerts + digests recipient
#
# These are already configured on the remote Supabase project; this block
# exists so a fresh clone can be repointed to a new Supabase project without
# guesswork.
