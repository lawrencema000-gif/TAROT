# Supabase Configuration (Required)
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# RevenueCat API Key for Mobile App Billing (Required for mobile purchases)
# Get your API key from: https://app.revenuecat.com
# This enables Google Play Billing for Android app
VITE_REVENUECAT_API_KEY=goog_xxxxxxxxxxxxxxxx

# Stripe API Keys for Web Version (Optional - for web payments)
# Get these from: https://dashboard.stripe.com/apikeys
# This enables direct Stripe payments on the web version
VITE_STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxx

# To use this file:
# 1. Copy this file to .env: cp .env.example .env
# 2. Replace the placeholder values with your actual credentials
# 3. Never commit .env to version control
# 4. For production, use live keys instead of test keys
