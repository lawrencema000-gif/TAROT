{
	"appId": "com.arcana.app",
	"appName": "Arcana",
	"webDir": "dist",
	"server": {
		"androidScheme": "https",
		"allowNavigation": [
			"*.supabase.co"
		]
	},
	"android": {
		"allowMixedContent": false,
		"backgroundColor": "#0a0a0f"
	},
	"plugins": {
		"SplashScreen": {
			"launchAutoHide": true,
			"backgroundColor": "#0a0a0f",
			"showSpinner": false,
			"androidScaleType": "CENTER_CROP",
			"splashFullScreen": true,
			"splashImmersive": true
		}
	}
}
