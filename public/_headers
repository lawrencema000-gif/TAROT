# Netlify _headers fallback. netlify.toml already declares these under the
# [[headers]] block, but some Netlify deploys fail to apply TOML rules (same
# pattern the existing _redirects file comments on). This file is the
# belt-and-suspenders source of truth served straight from `dist/_headers`.
#
# Keep the two in sync. If you change a header, update BOTH netlify.toml
# and this file.

/version.json
  Cache-Control: no-store

